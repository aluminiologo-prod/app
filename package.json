{
  "name": "aluminiologo-app",
  "version": "0.0.6",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "develop": "expo start --dev-client -c",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "prepare": "husky",
    "version:bump": "node scripts/bump-version.js bump",
    "version:revert": "node scripts/bump-version.js revert",
    "build:store": "eas build",
    "build:store:preview": "eas build --profile production",
    "build:develop": "eas build --profile development",
    "build:preview": "eas build --profile preview --clear-cache",
    "clean:install": "rm -rf node_modules/ && rm -rf yarn.lock && rm -rf android && rm -rf .expo && rm -rf ios && npm cache clean --force && yarn cache clean && yarn install"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.15.0",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "i18next": "^26.0.4",
    "lucide-react-native": "^1.8.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-i18next": "^17.0.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "babel-jest": "^30.3.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^55.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.16",
    "lint-staged": "^16.4.0",
    "react-test-renderer": "^19.2.5",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "@types/jest",
        "eslint-config-expo",
        "jest",
        "jest-expo"
      ]
    }
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0"
    ]
  }
}
